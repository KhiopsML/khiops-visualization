/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "module": "es2022",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "allowJs": true,
    "lib": ["es2022", "dom"],
    "types": ["jasmine", "node"],
    "paths": {
      "@khiops-library/*": ["./src/app/khiops-library/*"],
      "@khiops-menu/*": ["./src/app/khiops-menu/*"],
      "@khiops-treeview": ["./src/app/khiops-treeview"],
      "@khiops-hypertree": ["./src/app/khiops-hypertree"],
      "@khiops-visualization/*": ["./src/app/khiops-visualization/*"],
      "@khiops-covisualization/*": ["./src/app/khiops-covisualization/*"],
      "khiops-visualization-components": [
        "./dist/khiops-visualization-components/khiops-visualization-components",
        "./dist/khiops-visualization-components"
      ],
      "stream": ["./node_modules/stream-browserify"],
      "dockview-angular": ["./node_modules/dockview-angular/dist"]

    }
  },
  "exclude": ["node_modules", "./libs", "dist", "**/*.spec.ts"],
  "angularCompilerOptions": {
    "strictTemplates": false,
    "strictInjectionParameters": true
  }
}
